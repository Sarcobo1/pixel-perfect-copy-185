modules = ["web", "postgresql-16", "nodejs-22"]
[agent]
expertMode = true
stack = "GAMESTACK_JS"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PIXABAY_API_KEY = "56195538-2ef981256649e55a3f82697b9"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]
